{
  "name": "trading-lab",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "check": "pnpm typecheck && pnpm test",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingress": "node --experimental-strip-types src/ingress/server.ts",
    "worker": "node --experimental-strip-types src/worker/worker.ts",
    "platform:resume": "node --experimental-strip-types scripts/platform-resume.ts",
    "paper:monitor:resume": "node --experimental-strip-types scripts/paper-monitor-resume.mts",
    "analyst:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/strategy-analyst-eval.ts",
    "researcher:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/researcher-eval.ts",
    "builder:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/builder-eval.ts",
    "turn-interpreter:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/turn-interpreter-eval.ts",
    "operator-rag:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/operator-rag-eval.ts",
    "critic:eval": "node --experimental-strip-types --env-file-if-exists=.env scripts/strategy-critic-eval.ts",
    "operator-rag:reindex": "node --experimental-strip-types --env-file-if-exists=.env scripts/operator-rag-reindex.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/openai": "^3.0.69",
    "@hono/node-server": "^1.13.0",
    "@mastra/arize": "^1.3.1",
    "@mastra/core": "^1.41.0",
    "@mastra/observability": "^1.15.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@trading-backtester/sdk": "https://github.com/alexnikolskiy/trading-backtester/releases/download/sdk-v0.7.0/trading-backtester-sdk-0.7.0.tgz",
    "@trdlabs/sdk": "0.10.0",
    "bullmq": "^5.21.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "mprocs": "^0.9.6",
    "typescript": "^5.6.0",
    "esbuild": "^0.25.0",
    "vitest": "^2.1.0"
  }
}
