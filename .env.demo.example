# Demo — public, self-contained, key-free. Copy to .env.demo, then:
#   make demo            # pulls images from GHCR, then `up`
# Open http://localhost:8080

COMPOSE_PROJECT_NAME=trading-demo

# GHCR image tags. Every first-party image is pulled (built by each repo's
# "Publish image" workflow); pin a tag (e.g. sha-abc1234) for repeatability.
LAB_IMAGE_TAG=latest
MOCK_PLATFORM_IMAGE_TAG=latest
BACKTESTER_IMAGE_TAG=latest
OFFICE_SERVER_IMAGE_TAG=latest
OFFICE_WEB_IMAGE_TAG=latest

# Browser-facing host ports.
OFFICE_WEB_PORT=8080
OFFICE_SERVER_PORT=8787
# Backtester API on loopback (cross-repo E2E + host-side vitest).
BACKTESTER_HOST_PORT=8081

# Web UI (page) origin — used for office-server CORS.
OFFICE_CORS_ORIGIN=http://localhost:8080
# Public office-server (API) origin baked into the web build (browser -> office-server).
VITE_OFFICE_GATEWAY_URL=http://localhost:8787

# trading-lab service-to-service tokens. Dev values (safe to commit as an example).
# REQUIRED so the read API (dashboard data) and chat boot.
TRADING_LAB_READ_TOKEN=demo-read-token
TRADING_LAB_CHAT_TOKEN=demo-chat-token
TRADING_LAB_TASK_TOKEN=demo-task-token
TRADING_LAB_CALLBACK_TOKEN=demo-callback-token
# URL backtester uses to POST /callbacks/backtest-completed (docker: ingress service).
TRADING_LAB_CALLBACK_PUBLIC_URL=http://ingress:3000

# ── mock-platform ─────────────────────────────────────────────────────────────
# Raw bearer token that demo services present to mock-platform.
# MOCK_OPS_TOKENS in mock-platform must be set to sha256-hex of this value.
# Generate: openssl rand -hex 32
MOCK_OPS_TOKEN=demo-ops-token-change-me
# sha256-hex of MOCK_OPS_TOKEN above (mock-platform validates this hash, not the raw value).
# Generate: echo -n "demo-ops-token-change-me" | sha256sum | cut -d' ' -f1
MOCK_OPS_TOKENS=6dd4bdc53b914f84f0b3a25d4b2417e3b160008b7aa63502877b23903d3f247b
# Snapshot ref loaded by mock-platform (relative to its fixtures/ dir or an absolute path).
MOCK_SNAPSHOT_REF=fixtures/2026-06-22-to-2026-06-28-vps
MOCK_REPLAY_MODE=loop
MOCK_REPLAY_SPEED=1

# ── backtester ────────────────────────────────────────────────────────────────
# Bearer token that trading-lab presents to the backtester HTTP API.
BACKTESTER_AUTH_TOKEN=demo-backtester-token

# ── Agents + platform integration ─────────────────────────────────────────────
# Overridden by docker-compose.demo.yml to wire backtester + mock-platform.
# Do not change unless you know what you are doing.
TRADING_PLATFORM_INTEGRATION=backtester

# ── Optional: all agents with real LLM at once (one-knob family default) ────────
# Master switch for ALL agent adapters (strategy-analyst, researcher, critic, builder, turn-interpreter).
# Default fake (stubs, key-free). Set =mastra to make every agent use the real LLM at once.
# A per-agent <AGENT>_ADAPTER below still overrides this default.
# LAB_AGENTS_ADAPTER=mastra

# ── Optional: live LLM operator (L2) + evidence retrieval (L3) ──────────────────
# The demo is key-free by default (fake interpreter, no RAG). To run the real
# conversational operator, uncomment these and supply an OpenRouter key. The
# OPERATOR_* knobs are forwarded to ingress + worker by docker-compose.yml.
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# L2 — real turn interpretation (subject/goal/constraint) instead of the fake rule engine:
# TURN_INTERPRETER_ADAPTER=mastra
# TURN_INTERPRETER_MODEL=openrouter/google/gemini-3.1-flash-lite
# L3 — hybrid evidence retrieval (FTS + pgvector/bge-m3); requires OPENROUTER_API_KEY:
# OPERATOR_RAG_ENABLED=true

# Phoenix observability — Mastra agent tracing to the self-hosted phoenix service.
# UI at http://localhost:6006 (vps: behind the office reverse proxy with auth).
PHOENIX_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PROJECT_NAME=trading-lab
# Phoenix REST read API (office surfaces agent traces through trading-lab).
# Defaults to PHOENIX_COLLECTOR_ENDPOINT minus /v1/traces.
PHOENIX_READ_BASE_URL=http://phoenix:6006
# Optional Bearer token if the Phoenix instance has auth enabled.
PHOENIX_API_KEY=

# Research cycle configuration — per-trade context window sizing
TRADE_CONTEXT_WARMUP_MIN=150
TRADE_CONTEXT_TAIL_MIN=60
TRADE_CONTEXT_WINNERS_MAX=5
RESEARCHER_MAX_PER_PASS=5
