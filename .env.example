DATABASE_URL=postgres://lab:lab@localhost:5432/trading_lab
REDIS_URL=redis://localhost:6379
ARTIFACT_DIR=.artifacts
ENABLE_CRITIC_AGENT=false
INGRESS_PORT=3000
# Master switch for ALL agent adapters (strategy-analyst, researcher, critic, builder, turn-interpreter).
# Default fake (stubs, key-free). Set =mastra to make every agent use the real LLM at once.
# A per-agent <AGENT>_ADAPTER below still overrides this default.
# LAB_AGENTS_ADAPTER=mastra
STRATEGY_ANALYST_ADAPTER=fake
# StrategyAnalyst model. Default chosen from the fresh-gen N=5 stable eval
# (fixture long-oi, judge=claude-opus-4.8 via OpenRouter, run 20260616T223641Z).
# Decided by analyst:eval (repeat=3, long-oi + short-pump, opus judge). Default = gpt-5.5:
# best on judge AND the granular scoreProfile on both directions (judge 0.97/0.973,
# secProfile 0.942). A structured-extraction prompt did NOT close grok's gap (secProfile
# ~0.83), so the cheap model is a fallback, not the default. Analyst runs 1x/onboarding → cost bounded.
STRATEGY_ANALYST_MODEL=openrouter/openai/gpt-5.5
# Candidates (swap STRATEGY_ANALYST_MODEL to one of these):
#   openrouter/x-ai/grok-4.3                    # cheap/fast fallback (~10s, cheapest): judge 0.93-0.957 but secProfile ~0.83
#   openrouter/anthropic/claude-opus-4.8        # ties gpt-5.5 on quality but pricier/slower, no edge
#   openrouter/google/gemini-3.1-pro-preview    # NOT an analyst here: det FAILs / judge 0.90 — avoid
ANTHROPIC_API_KEY=
RUN_LLM_TESTS=false

# === LLM provider configuration (SP-4.5) ===
# MODEL_PROVIDER selects the default provider for "mastra" adapters: anthropic | openai | openrouter
# Per-role override: prefix a role model id, e.g. RESEARCHER_MODEL=openai/gpt-4o
# OpenRouter ids whose vendor is anthropic/openai need the openrouter/ prefix:
#   RESEARCHER_MODEL=openrouter/anthropic/claude-3.5-sonnet

# --- Demo A: no-key fake (DEFAULT) — docker compose up works with NO LLM key ---
# Leave *_ADAPTER unset (they default to "fake"). MODEL_PROVIDER/keys are then irrelevant.

# --- Demo B: OpenAI ---
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# RESEARCHER_ADAPTER=mastra
# RESEARCHER_MODEL=gpt-4o

# --- Demo C: OpenRouter (recommended for production) ---
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# RESEARCHER_ADAPTER=mastra
# RESEARCHER_MODEL=openrouter/openai/gpt-5.5   # winner of 2026-06-18 bake-off; grok-4.3 is a cheaper backup
# BUILDER_ADAPTER=mastra
BUILDER_MODEL=openrouter/deepseek/deepseek-v4-pro  # winner: judge=0.992 (bakeoff 2026-06-18); gemini-3.1-pro-preview is strong alt (judge=1.000, faster)

# SP-4.6 Chat ingress / TurnInterpreter (defaults keep docker compose key-free)
# Renamed from INTENT_CLASSIFIER_* (eval #69/#71 selected gemini-3.1-flash-lite as interpreter model)
TURN_INTERPRETER_ADAPTER=fake             # fake | mastra
TURN_INTERPRETER_MODEL=openrouter/google/gemini-3.1-flash-lite
TURN_INTERPRETER_MIN_CONFIDENCE=0.6
CHAT_MAX_MESSAGE_CHARS=4000
# SP-6.1 Chat ingress service-to-service auth (fail-closed: unset -> POST /chat/messages returns 503)
TRADING_LAB_CHAT_TOKEN=dev-chat-token     # service-to-service token for POST /chat/messages
# production MUST override this value
# MUST differ from TRADING_LAB_READ_TOKEN (read API and chat ingress are separate boundaries)
# browser never calls trading-lab directly — the office backend is the only caller
# INGRESS_PORT must not be public without network protection (reverse proxy / firewall)

# SP-6.2 Task + callback ingress service-to-service auth (fail-closed: unset -> 503)
TRADING_LAB_TASK_TOKEN=dev-task-token           # service-to-service token for POST /tasks
TRADING_LAB_CALLBACK_TOKEN=dev-callback-token   # service-to-service token for POST /callbacks/backtest-completed
# Public ingress URL (no trailing slash). When set with TRADING_LAB_CALLBACK_TOKEN, lab passes
# {base}/callbacks/backtest-completed?token=… to backtester/platform on submit (push completion).
TRADING_LAB_CALLBACK_PUBLIC_URL=http://localhost:3000
# production MUST override these values
# each ingress token MUST be distinct (read / chat / task / callback are separate boundaries)
# /tasks is NOT the office path — trading-office uses /chat/messages

# --- Operator RAG (evidence-first retrieval; disabled by default) ---
OPERATOR_RAG_ENABLED=false
OPERATOR_EMBEDDING_PROVIDER=openrouter
OPERATOR_EMBEDDING_MODEL=baai/bge-m3
OPERATOR_EMBEDDING_DIMENSIONS=1024
OPERATOR_RETRIEVAL_INDEX_VERSION=1
OPERATOR_RETRIEVAL_SOFT_TIMEOUT_MS=5000
OPERATOR_RETRIEVAL_HARD_TIMEOUT_MS=10000
# Retrieval limit knobs (defaults shown):
OPERATOR_RETRIEVAL_LEXICAL_LIMIT=50
OPERATOR_RETRIEVAL_VECTOR_LIMIT=50
OPERATOR_RETRIEVAL_FUSED_LIMIT=20
# Conditional reranker (scaffold; OFF by default). Set OPERATOR_RERANKER=mastra to enable LLM
# relevance reranking over the RRF-fused candidates (RRF stays the baseline + fallback).
OPERATOR_RERANKER=none
OPERATOR_RERANK_TIMEOUT_MS=1500
OPERATOR_RERANK_LIMIT=5
OPERATOR_RERANK_MIN_CANDIDATES=10
OPERATOR_RERANK_RRF_MARGIN=0.002
# When OPERATOR_RAG_ENABLED=true, DATABASE_URL and OPENROUTER_API_KEY are required.

# SP-5 Read API
READ_API_PORT=3100
TRADING_LAB_READ_TOKEN=

# SP-6 Agent activity projection + internal stream (defaults shown)
AGENT_ACTIVITY_REBUILD_WINDOW_HOURS=24
AGENT_ACTIVITY_TRACE_LIMIT=50
AGENT_EVENT_STREAM_SAFETY_TICK_MS=5000
AGENT_EVENT_STREAM_HEARTBEAT_MS=15000

# --- trading-platform research integration (read-only ops-read via @trading-platform/sdk) ---
# Selects the research-platform backend: 'mock' (default, in-process) or 'backtester' (HTTP via
# @trading-backtester/sdk). The MCP gateway integration was retired; runtime boot never contacts
# trading-platform. @trading-platform/sdk is the published 0.5.0 release (ops-read only).
TRADING_PLATFORM_INTEGRATION=mock

# Phoenix observability (off by default). Set PHOENIX_ENABLED=true and run a Phoenix
# instance to export Mastra agent traces. In docker the endpoint is http://phoenix:6006/v1/traces.
PHOENIX_ENABLED=false
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=trading-lab
# Phoenix REST read API (office surfaces agent traces through trading-lab).
# Defaults to PHOENIX_COLLECTOR_ENDPOINT minus /v1/traces.
PHOENIX_READ_BASE_URL=http://localhost:6006
# Optional Bearer token if the Phoenix instance has auth enabled.
PHOENIX_API_KEY=

# --- Pre-flight Strategy Critic (ON by default; single + grok-4.3, the eval verdict) ---
# A "ruthless market opponent" critiques a NEW strategy's raw text. Chat onboarding is HITL (the
# operator chooses to apply the improvements or analyze as-is); crawler/direct-/tasks onboarding is
# auto. A critic failure never blocks onboarding (fail-soft). Set STRATEGY_PREFLIGHT_CRITIQUE=false to disable.
STRATEGY_PREFLIGHT_CRITIQUE=true
# Adapter follows LAB_AGENTS_ADAPTER (the agent-family default) unless set explicitly. The default-on critic
# uses the FAKE echo adapter in keyless dev; the real grok-4.3 critic needs mastra + OPENROUTER_API_KEY.
STRATEGY_CRITIC_ADAPTER=fake          # fake | mastra (inherits LAB_AGENTS_ADAPTER when unset; mastra needs OPENROUTER_API_KEY)
STRATEGY_CRITIC_MODE=single           # single (1 combined call) | two_stage (critic→refiner, 2 LLM calls)
STRATEGY_CRITIC_MODEL=openrouter/x-ai/grok-4.3
# Refiner model (two_stage only); defaults to STRATEGY_CRITIC_MODEL when left blank.
STRATEGY_REFINER_MODEL=

# Market history read (CanonicalRowV2) for commitXTermMath; defaults to the ops-read URL
LAB_MARKET_HISTORY_URL=
MARKET_HISTORY_LOOKBACK_DAYS=7

# Research task configuration
# Cumulative LLM token budget per research chain (correlationId-keyed). Gates: between
# research cycles AND between WFO sweep rounds. Unset = unlimited.
RESEARCH_TASK_TOKEN_BUDGET=

# Research cycle configuration — per-trade context window sizing
# Warmup window: bars before the trade opens (context for position entry analysis)
TRADE_CONTEXT_WARMUP_MIN=150
# Tail window: bars after the trade closes (context for exit quality analysis)
TRADE_CONTEXT_TAIL_MIN=60
# Max winning trades surfaced to the profit-improvement researcher pass (default 5)
TRADE_CONTEXT_WINNERS_MAX=5
# Max hypotheses each researcher pass proposes (loss + profit) (default 5).
# NOTE: effectively bounded by MAX_HYPOTHESES_PER_CYCLE — each pass emits min(RESEARCHER_MAX_PER_PASS, MAX_HYPOTHESES_PER_CYCLE);
# with both at the default 5 and winners present, a cycle yields up to 5 loss + 5 profit = 10 hypotheses.
RESEARCHER_MAX_PER_PASS=5

# Lab-side backtest parallelism. Total in-flight pressure on the backtester
# = LAB_QUEUE_CONCURRENCY × RESEARCH_GRID_CONCURRENCY (defaults 1 × 4 = 4,
# matching the backtester's default WORKER_CONCURRENCY=4). The backtester has
# no ingress backpressure yet — raise these deliberately.
RESEARCH_GRID_CONCURRENCY=4
LAB_QUEUE_CONCURRENCY=1

# Platform paper-intake (feature 036/066). Unset URL = paper bridge disabled (kill-switch):
# PAPER_CANDIDATE verdicts emit paper.intake_skipped instead of submitting.
LAB_PAPER_INTAKE_URL=
LAB_PAPER_INTAKE_TOKEN=

# --- paper.monitor (slice G4): adaptive paper-observation window + self-reschedule poll ---
# Delay (ms) between paper.monitor self-reschedule polls (default 6h).
PAPER_MONITOR_POLL_MS=21600000
# Trade count that closes the observation window with full confidence.
PAPER_WINDOW_MIN_TRADES=30
# At PAPER_WINDOW_MAX_DAYS, this many closed trades still closes the window (flagged low-confidence).
PAPER_WINDOW_LOW_CONFIDENCE_THRESHOLD=15
# Minimum elapsed days before the window can ever complete, even for high-frequency strategies.
PAPER_WINDOW_MIN_DAYS=3
# Elapsed days at which the window forces a verdict (normal or low-confidence).
PAPER_WINDOW_MAX_DAYS=30
# Max days the monitor waits for the live paper run to appear before giving up (stalled).
PAPER_MONITOR_MAX_WAIT_DAYS=7
