# VPS — production-like, detached. Copy to .env.vps and fill the CHANGE_ME values.
# Run:
#   docker compose -f docker-compose.yml -f docker-compose.vps.yml --env-file .env.vps up --build -d
#   (office included; add --profile office explicitly if invoking compose directly without `make vps`)

COMPOSE_PROJECT_NAME=trading-vps

# U6 (F5a) — the immutable, digest-pinned lab image shared by migrate/ingress/worker.
# REQUIRED: repo@sha256:<64 hex> only — never a mutable tag (latest, sha-<short>). Published
# by .github/workflows/docker-publish.yml; see docs/docker-vps.md and
# infra/scripts/unit-deploy.sh. Note: `make config` only checks that the variable is NON-EMPTY —
# it renders fine with the CHANGE_ME placeholder. The digest is enforced for real by
# infra/scripts/unit-deploy.sh's regex check, and a placeholder fails at `docker compose pull`.
LAB_U6_IMAGE=ghcr.io/trdlabs/lab@sha256:CHANGE_ME

# Absolute checkout paths on the server. Office is OPTIONAL — U6 (migrate/ingress/worker) never
# depends on it; leave TRADING_OFFICE_PATH unset and omit --profile office to run without an
# office checkout at all (see docker-compose.vps.yml's `profiles: ["office"]` guard).
TRADING_OFFICE_PATH=/opt/trading-office

# Publish address: 0.0.0.0 to expose directly, or 127.0.0.1 behind a host reverse proxy.
BIND_ADDR=0.0.0.0
OFFICE_WEB_PORT=8080
OFFICE_SERVER_PORT=8787

# Web UI (page) origin — used for office-server CORS.
OFFICE_CORS_ORIGIN=https://office.example.com
# Public office-server (API) origin baked into the web build (browser -> office-server).
# Typically a DIFFERENT origin from the UI. Same-origin variant: set both to the UI origin
# and have a reverse proxy route /api/office/* + the WS upgrade to office-server.
VITE_OFFICE_GATEWAY_URL=https://office-api.example.com

# Operator password for office-server (SEC-O1/O2). office-server runs in connected mode here,
# so it REFUSES TO START while this is empty — that refusal is the intended state until a unique
# value is provisioned out of band (never through git, and never reused from another host).
# Deliberately left empty: any committed placeholder would be a working password the moment it
# reached a host, and this file is the staging/production template.
OFFICE_OPERATOR_PASSWORD=

# trading-lab service-to-service tokens — placeholders only; NEVER commit real values.
TRADING_LAB_READ_TOKEN=CHANGE_ME
TRADING_LAB_CHAT_TOKEN=CHANGE_ME
TRADING_LAB_TASK_TOKEN=CHANGE_ME
TRADING_LAB_CALLBACK_TOKEN=CHANGE_ME

# Agents/platform: keep fake/mock unless deliberately enabling a real runtime.
TRADING_PLATFORM_INTEGRATION=mock

# Read-only private operational source (ON by default for vps).
OFFICE_PLATFORM_ENABLED=true
TRADING_PLATFORM_READ_URL=http://internal-platform-host:8839
TRADING_PLATFORM_READ_TOKEN=CHANGE_ME

# Only used by the optional `--profile private-path-check` guard:
PRIVATE_RUNTIME_PATH=/opt/trading-platform

# Phoenix observability — Mastra agent tracing to the self-hosted phoenix service.
# UI at http://localhost:6006 (vps: behind the office reverse proxy with auth).
PHOENIX_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PROJECT_NAME=trading-lab
# Phoenix REST read API (office surfaces agent traces through trading-lab).
# Defaults to PHOENIX_COLLECTOR_ENDPOINT minus /v1/traces.
PHOENIX_READ_BASE_URL=http://phoenix:6006
# Optional Bearer token if the Phoenix instance has auth enabled.
PHOENIX_API_KEY=
